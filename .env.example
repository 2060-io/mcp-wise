# Wise API token (required in stdio mode; optional in http mode for corporate/single-account deployments)
WISE_API_TOKEN=your_wise_api_token_here

# Use Wise Sandbox API (true/false)
WISE_IS_SANDBOX=false

# MCP Server transport mode (http/stdio)
MODE=stdio

# --- Access control (choose one mode) ---

# Corporate mode: single Wise account shared by all users.
# Set WISE_API_TOKEN above and restrict access to specific profile IDs.
# Comma-separated list of allowed Wise profile IDs.
# Example: WISE_ALLOWED_PROFILES=13614771,69973314
#WISE_ALLOWED_PROFILES=

# End-user mode: each user provides their own token (accessMode: user-controlled).
# Do NOT set WISE_API_TOKEN. Restrict access by profile type instead.
# Comma-separated list of allowed profile types (default: personal).
# Example: WISE_ALLOWED_PROFILE_TYPES=personal,business
#WISE_ALLOWED_PROFILE_TYPES=personal